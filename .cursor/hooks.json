{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "command": "node .cursor/hooks/session-git-context.mjs"
      }
    ],
    "beforeShellExecution": [
      {
        "command": "node .cursor/hooks/git-guard.mjs",
        "matcher": "git ",
        "failClosed": false
      }
    ]
  }
}
